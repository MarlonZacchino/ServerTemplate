# Local smoke-test mode. Open http://127.0.0.1:8080 after installation.
STYLES4DOGS_CADDY_SITE_ADDRESS=http://127.0.0.1:8080

# The C server remains reachable only on loopback.
STYLES4DOGS_CADDY_UPSTREAM=127.0.0.1:31337

# For public deployment, replace the site address with the real DNS name:
# STYLES4DOGS_CADDY_SITE_ADDRESS=styles4dogs.example

# Must match STYLES4DOGS_TRUSTED_PROXY_TOKEN in server.env.
STYLES4DOGS_TRUSTED_PROXY_TOKEN=replace-with-random-token
