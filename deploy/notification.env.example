# Styling 4 Dogs - Vorlage für /etc/styles4dogs/notification.env
#
# Neue Installationen verbinden das Salon-Postfach bevorzugt im geschützten
# Adminbereich unter /admin/notifications. Die dort eingegebenen Zugangsdaten
# werden verschlüsselt im Secrets-Verzeichnis gespeichert und haben Vorrang.
#
# Die folgenden Variablen bleiben als Migrations-Fallback für bestehende
# Installationen verfügbar. Keine echten Zugangsdaten in Git eintragen.
# Beispiel für STARTTLS: smtp://smtp.example.de:587
# Beispiel für implizites TLS: smtps://smtp.example.de:465

STYLES4DOGS_SMTP_URL=
STYLES4DOGS_SMTP_USERNAME=
STYLES4DOGS_SMTP_PASSWORD=
STYLES4DOGS_SMTP_FROM_ADDRESS=
STYLES4DOGS_SMTP_FROM_NAME=Styling 4 Dogs
STYLES4DOGS_ADMIN_NOTIFICATION_EMAIL=
STYLES4DOGS_NOTIFY_ADMIN_NEW_BOOKING=0
