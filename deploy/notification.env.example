# Styles 4 Dogs - Vorlage für /etc/styles4dogs/notification.env
#
# Enthält die Zugangsdaten für den SMTP-Versand. Die installierte Datei wird
# mit Modus 0640 als root:styles4dogs angelegt und niemals in Git befüllt.
# Beispiel für STARTTLS: smtp://smtp.example.de:587
# Beispiel für implizites TLS: smtps://smtp.example.de:465

STYLES4DOGS_SMTP_URL=
STYLES4DOGS_SMTP_USERNAME=
STYLES4DOGS_SMTP_PASSWORD=
STYLES4DOGS_SMTP_FROM_ADDRESS=
STYLES4DOGS_SMTP_FROM_NAME=Styles 4 Dogs
