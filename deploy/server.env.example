# Styling 4 Dogs - Vorlage für /etc/styles4dogs/server.env
#
# Diese Datei enthält kein Passwort. Sie bleibt trotzdem root-verwaltet und
# wird mit 0640 installiert, damit nur root und die Gruppe styles4dogs lesen.
# admin.auth liegt absichtlich in einem getrennten, für den Server schreibbaren
# Unterordner. Dadurch kann der Prozess server.env nicht verändern.

STYLES4DOGS_BIND_ADDRESS=127.0.0.1
STYLES4DOGS_PORT=31337
STYLES4DOGS_DOCUMENT_ROOT=/var/www/styles4dogs
STYLES4DOGS_SECRETS_DIR=/etc/styles4dogs/secrets
STYLES4DOGS_AUTH_FILE=/etc/styles4dogs/secrets/admin.auth
STYLES4DOGS_DATA_DIR=/var/lib/styles4dogs
STYLES4DOGS_DATABASE_FILE=/var/lib/styles4dogs/styles4dogs.db
STYLES4DOGS_LEGACY_BOOKING_FILE=/var/lib/styles4dogs/bookings.txt

# Generated during installation. Use the same value in caddy.env.
# Minimum 32 characters; letters, digits, '-' and '_' only.
STYLES4DOGS_TRUSTED_PROXY_TOKEN=replace-with-random-token

# Öffentliche Salon- und Linkdaten für E-Mails, ICS-Dateien und Schnellaktionen.
STYLES4DOGS_SALON_NAME=Styling 4 Dogs
STYLES4DOGS_SALON_ADDRESS=
STYLES4DOGS_SALON_PHONE=
STYLES4DOGS_PUBLIC_BASE_URL=http://127.0.0.1:8080
STYLES4DOGS_DEFAULT_PHONE_COUNTRY_CODE=49
