# Styles 4 Dogs - Beispiel für /etc/styles4dogs/server.env
# Diese Datei enthält keine Passwörter. Dateirechte trotzdem auf 0640 begrenzen.

STYLES4DOGS_BIND_ADDRESS=127.0.0.1
STYLES4DOGS_PORT=31337
STYLES4DOGS_DOCUMENT_ROOT=/var/www/styles4dogs
STYLES4DOGS_SECRETS_DIR=/etc/styles4dogs
STYLES4DOGS_AUTH_FILE=/etc/styles4dogs/admin.auth
STYLES4DOGS_DATA_DIR=/var/lib/styles4dogs
STYLES4DOGS_DATABASE_FILE=/var/lib/styles4dogs/styles4dogs.db
STYLES4DOGS_LEGACY_BOOKING_FILE=/var/lib/styles4dogs/bookings.txt
